/* ==========================================
   PART 13
   STORE • TICKETS • NEWSLETTER
==========================================*/

/* Shared Page Layout */

.store-page,
.tickets-page,
.newsletter-page{

    background:#b30000;
    color:#ffffff;
    min-height:100vh;
    padding:120px 8%;

}

.store-container,
.ticket-container,
.newsletter-container{

    max-width:1100px;
    margin:auto;

}

.store-page h1,
.tickets-page h1,
.newsletter-page h1{

    text-align:center;
    font-size:3rem;
    letter-spacing:3px;
    margin-bottom:25px;
    text-transform:uppercase;

}

.store-page p,
.tickets-page p,
.newsletter-page p{

    text-align:center;
    color:#f3f3f3;
    max-width:760px;
    margin:0 auto 50px;

}

/* Cards */

.store-grid,
.ticket-grid{

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:35px;

}

.store-item,
.ticket-card{

    background:#ffffff;
    color:#111;
    border-radius:18px;
    overflow:hidden;
    transition:.35s ease;

}

.store-item:hover,
.ticket-card:hover{

    transform:translateY(-8px);
    box-shadow:0 18px 45px rgba(0,0,0,.25);

}

.store-item img,
.ticket-card img{

    width:100%;
    height:300px;
    object-fit:cover;

}

.store-content,
.ticket-content{

    padding:30px;

}

.store-content h3,
.ticket-content h3{

    margin-bottom:15px;

}

.price{

    font-size:1.2rem;
    font-weight:700;
    margin:15px 0;

}

/* Newsletter */

.newsletter-form{

    max-width:650px;
    margin:40px auto;
    display:flex;
    gap:15px;
    flex-wrap:wrap;

}

.newsletter-form input{

    flex:1;
    min-width:250px;
    padding:18px;
    border:none;
    border-radius:50px;
    font-size:1rem;

}

.newsletter-form button{

    padding:18px 40px;
    border:none;
    border-radius:50px;
    background:#111;
    color:#fff;
    cursor:pointer;
    transition:.3s;

}

.newsletter-form button:hover{

    background:#000;
    transform:translateY(-3px);

}

/* Buttons */

.buy-btn,
.ticket-btn{

display:inline-block;
margin-top:18px;
padding:15px 34px;
border:2px solid #111;
text-transform:uppercase;
font-weight:600;
letter-spacing:2px;
transition:.35s;

}

.buy-btn:hover,
.ticket-btn:hover{

background:#111;
color:#fff;

}

/* Mobile */

@media(max-width:768px){

.store-page h1,
.tickets-page h1,
.newsletter-page h1{

font-size:2.2rem;

}

.newsletter-form{

flex-direction:column;

}

.newsletter-form input,
.newsletter-form button{

width:100%;

}

.store-item img,
.ticket-card img{

height:220px;

}

}
