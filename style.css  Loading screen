/* ==========================================
   PART 17 - FINAL OPTIMIZATION
========================================== */

/* Loading Screen */

#loader{

position:fixed;

top:0;

left:0;

width:100%;

height:100%;

background:#7a0b0b;

display:flex;

justify-content:center;

align-items:center;

z-index:999999;

transition:opacity .7s ease;

}

.loader-logo{

color:#ffffff;

font-size:2rem;

font-weight:700;

letter-spacing:8px;

animation:pulse 1.5s infinite;

}

@keyframes pulse{

0%{

opacity:.4;

}

50%{

opacity:1;

}

100%{

opacity:.4;

}

}

/* Smooth scrolling */

html{

scroll-behavior:smooth;

}

/* Better selection */

::selection{

background:#7a0b0b;

color:#ffffff;

}

/* Prevent image dragging */

img{

-webkit-user-drag:none;

user-select:none;

}

/* Smooth transitions */

*{

transition:

background-color .3s,

color .3s,

border-color .3s;

}
